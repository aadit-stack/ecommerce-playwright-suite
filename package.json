{
  "name": "saucedemo-playwright",
  "version": "1.0.0",
  "description": "Playwright end-to-end test automation for SauceDemo using the Page Object Model pattern with Allure reporting",
  "scripts": {
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:headed": "npx playwright test --headed",
    "allure:generate": "npx allure generate allure-results -o allure-report --clean",
    "allure:open": "npx allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
  "keywords": ["playwright", "testing", "e2e", "saucedemo", "automation"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.6.0"
  }
}
